NODE_ENV=development
# Keep whichever you use; Config.ts accepts PORT/port/Port
PORT=3000
VERIFY_TOKEN=your-verify-token
LOG_LEVEL=info
LOG_PRETTY=true
CORS_ORIGINS=*
JSON_BODY_LIMIT=1mb
WEBHOOK_PATH=/webhook

QUEUE_CONCURRENCY=4
QUEUE_MAX_ATTEMPTS=3

# Idempotency TTL in seconds
IDEMPOTENCY_TTL_SECONDS=86400

SHUTDOWN_TIMEOUT_MS=10000

Database_url='mongodb://127.0.0.1:27017/DeviceTrace'
